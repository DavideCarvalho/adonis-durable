{
  "name": "@agora/durable-transport-db",
  "version": "0.1.0",
  "description": "A poll-based, DB-table-backed Transport for @agora/durable-core over AdonisJS Lucid — run durable remote steps cross-process using only your database, no Redis/queue infra. Part of the Agora ecosystem.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DavideCarvalho/adonis-durable.git",
    "directory": "packages/transport-db"
  },
  "author": "Davi Carvalho <davi@goflip.ai>",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    },
    "./configure": {
      "types": "./dist/configure.d.ts",
      "import": "./dist/configure.js",
      "default": "./dist/configure.js"
    }
  },
  "files": ["dist/", "README.md", "DESIGN.md", "CHANGELOG.md"],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json && pnpm run copy:stubs",
    "copy:stubs": "mkdir -p dist/stubs/database/migrations && cp -r stubs/database/migrations/. dist/stubs/database/migrations/",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@agora/durable-core": "workspace:^"
  },
  "peerDependencies": {
    "@adonisjs/core": "^6.12.0",
    "@adonisjs/lucid": "^21.0.0"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^7.8.0",
    "@adonisjs/core": "^6.17.0",
    "@adonisjs/lucid": "^21.6.0",
    "@agora/durable-core": "workspace:*",
    "@agora/durable-testing": "workspace:*",
    "@types/node": "^20.0.0",
    "better-sqlite3": "^11.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0",
    "zod": "^3.23.0"
  },
  "engines": { "node": ">=20.6.0" },
  "keywords": [
    "adonisjs",
    "adonis",
    "durable",
    "workflow",
    "lucid",
    "database",
    "transport",
    "agora"
  ]
}
