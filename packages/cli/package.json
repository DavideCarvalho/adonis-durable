{
  "name": "@agora/durable-cli",
  "version": "0.1.0",
  "description": "AdonisJS ace commands to operate the @agora/durable workflow engine — run the worker loop, list runs, and retry runs. Part of the Agora ecosystem.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DavideCarvalho/adonis-durable.git",
    "directory": "packages/cli"
  },
  "author": "Davi Carvalho <davi@goflip.ai>",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    },
    "./commands": {
      "types": "./dist/commands/main.d.ts",
      "import": "./dist/commands/main.js",
      "default": "./dist/commands/main.js"
    },
    "./commands/*": {
      "types": "./dist/commands/*.d.ts",
      "import": "./dist/commands/*.js",
      "default": "./dist/commands/*.js"
    },
    "./configure": {
      "types": "./dist/configure.d.ts",
      "import": "./dist/configure.js",
      "default": "./dist/configure.js"
    }
  },
  "files": ["dist/", "README.md", "CHANGELOG.md"],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@agora/durable-core": "workspace:^"
  },
  "peerDependencies": {
    "@adonisjs/core": "^6.12.0"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^7.8.0",
    "@adonisjs/core": "^6.17.0",
    "@agora/durable-core": "workspace:*",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  },
  "engines": { "node": ">=20.6.0" },
  "keywords": ["adonisjs", "adonis", "durable", "workflow", "ace", "cli", "worker", "agora"]
}
