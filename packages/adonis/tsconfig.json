{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist",
    "tsBuildInfoFile": ".tsbuildinfo",
    "types": ["node"],
    "experimentalDecorators": true
  },
  "include": [
    "src/**/*.ts",
    "providers/**/*.ts",
    "commands/**/*.ts",
    "configure.ts",
    "stubs/main.ts"
  ],
  "exclude": ["**/*.spec.ts", "**/*.test.ts", "test/**", "dist/**"]
}
