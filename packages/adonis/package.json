{
  "name": "@adonis-agora/durable",
  "version": "0.11.0",
  "description": "Durable cross-app workflows for AdonisJS — deterministic replay engine, AdonisJS binding, ace commands, dashboard, OpenTelemetry, Telescope, testing harness and Redis admission, all in one package. Part of the Agora ecosystem.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DavideCarvalho/adonis-durable.git",
    "directory": "packages/adonis"
  },
  "author": "Davi Carvalho <davi@goflip.ai>",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    },
    "./services/main": {
      "types": "./dist/src/services/main.d.ts",
      "import": "./dist/src/services/main.js",
      "default": "./dist/src/services/main.js"
    },
    "./worker": {
      "types": "./dist/src/worker-runtime/index.d.ts",
      "import": "./dist/src/worker-runtime/index.js",
      "default": "./dist/src/worker-runtime/index.js"
    },
    "./durable_provider": {
      "types": "./dist/providers/durable_provider.d.ts",
      "import": "./dist/providers/durable_provider.js",
      "default": "./dist/providers/durable_provider.js"
    },
    "./dashboard_provider": {
      "types": "./dist/providers/dashboard_provider.d.ts",
      "import": "./dist/providers/dashboard_provider.js",
      "default": "./dist/providers/dashboard_provider.js"
    },
    "./configure": {
      "types": "./dist/configure.d.ts",
      "import": "./dist/configure.js",
      "default": "./dist/configure.js"
    },
    "./otel": {
      "types": "./dist/src/otel/index.d.ts",
      "import": "./dist/src/otel/index.js",
      "default": "./dist/src/otel/index.js"
    },
    "./telescope": {
      "types": "./dist/src/telescope/index.d.ts",
      "import": "./dist/src/telescope/index.js",
      "default": "./dist/src/telescope/index.js"
    },
    "./dashboard": {
      "types": "./dist/src/dashboard/index.d.ts",
      "import": "./dist/src/dashboard/index.js",
      "default": "./dist/src/dashboard/index.js"
    },
    "./testing": {
      "types": "./dist/src/testing-kit/index.d.ts",
      "import": "./dist/src/testing-kit/index.js",
      "default": "./dist/src/testing-kit/index.js"
    },
    "./testing/conformance": {
      "types": "./dist/src/testing-kit/conformance.d.ts",
      "import": "./dist/src/testing-kit/conformance.js",
      "default": "./dist/src/testing-kit/conformance.js"
    },
    "./hooks/workflows": {
      "types": "./dist/src/hooks/workflows.d.ts",
      "import": "./dist/src/hooks/workflows.js",
      "default": "./dist/src/hooks/workflows.js"
    },
    "./hooks/steps": {
      "types": "./dist/src/hooks/steps.d.ts",
      "import": "./dist/src/hooks/steps.js",
      "default": "./dist/src/hooks/steps.js"
    },
    "./admission-redis": {
      "types": "./dist/src/admission-redis/index.d.ts",
      "import": "./dist/src/admission-redis/index.js",
      "default": "./dist/src/admission-redis/index.js"
    },
    "./control-plane-redis": {
      "types": "./dist/src/control-plane-redis/index.d.ts",
      "import": "./dist/src/control-plane-redis/index.js",
      "default": "./dist/src/control-plane-redis/index.js"
    },
    "./commands": {
      "types": "./dist/commands/main.d.ts",
      "import": "./dist/commands/main.js",
      "default": "./dist/commands/main.js"
    },
    "./commands/*": {
      "types": "./dist/commands/*.d.ts",
      "import": "./dist/commands/*.js",
      "default": "./dist/commands/*.js"
    }
  },
  "files": ["dist/", "README.md", "CHANGELOG.md"],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json && pnpm run copy:stubs",
    "copy:stubs": "mkdir -p dist/stubs/config dist/stubs/database/migrations dist/stubs/make/workflow dist/assets && cp stubs/config/durable.stub dist/stubs/config/durable.stub && cp stubs/config/durable_dashboard.stub dist/stubs/config/durable_dashboard.stub && cp -r stubs/database/migrations/. dist/stubs/database/migrations/ && cp stubs/make/workflow/main.stub dist/stubs/make/workflow/main.stub && cp assets/dashboard.html dist/assets/dashboard.html",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "bullmq": "^5.0.0",
    "zod": "^3.23.0"
  },
  "peerDependencies": {
    "@adonisjs/assembler": "^8.4.0",
    "@adonisjs/core": "^7.3.0",
    "@adonisjs/lucid": "^22.4.0",
    "@adonisjs/queue": "^0.6.0",
    "@adonisjs/redis": "^9.2.0",
    "@opentelemetry/api": "^1.0.0",
    "cron-parser": "^4.0.0 || ^5.0.0",
    "ioredis": "^5.0.0",
    "vitest": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "@adonisjs/assembler": {
      "optional": true
    },
    "@adonisjs/lucid": {
      "optional": true
    },
    "@adonisjs/queue": {
      "optional": true
    },
    "@adonisjs/redis": {
      "optional": true
    },
    "@opentelemetry/api": {
      "optional": true
    },
    "cron-parser": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    },
    "vitest": {
      "optional": true
    }
  },
  "devDependencies": {
    "@adonisjs/assembler": "^8.4.0",
    "@adonisjs/core": "^7.3.0",
    "@adonisjs/lucid": "^22.4.0",
    "@adonisjs/queue": "^0.6.1",
    "@adonisjs/redis": "^9.2.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/context-async-hooks": "^1.30.0",
    "@opentelemetry/sdk-trace-base": "^1.30.0",
    "@types/node": "^20.0.0",
    "better-sqlite3": "^11.0.0",
    "cron-parser": "^4.9.0",
    "ioredis": "^5.4.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0",
    "zod": "^3.25.0"
  },
  "engines": {
    "node": ">=20.6.0"
  },
  "keywords": [
    "adonisjs",
    "adonis",
    "durable",
    "workflow",
    "saga",
    "replay",
    "dashboard",
    "opentelemetry",
    "telescope",
    "testing",
    "agora"
  ]
}
