{
  "name": "@agora/durable",
  "version": "0.1.0",
  "description": "AdonisJS binding for @agora/durable-core — a container-resolved durable workflow engine. Part of the Agora ecosystem.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DavideCarvalho/adonis-durable.git",
    "directory": "packages/adonis"
  },
  "author": "Davi Carvalho <davi@goflip.ai>",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    },
    "./durable_provider": {
      "types": "./dist/providers/durable_provider.d.ts",
      "import": "./dist/providers/durable_provider.js",
      "default": "./dist/providers/durable_provider.js"
    },
    "./configure": {
      "types": "./dist/configure.d.ts",
      "import": "./dist/configure.js",
      "default": "./dist/configure.js"
    }
  },
  "files": ["dist/", "README.md", "CHANGELOG.md"],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json && pnpm run copy:stubs",
    "copy:stubs": "mkdir -p dist/stubs/config && cp stubs/config/durable.stub dist/stubs/config/durable.stub",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@agora/durable-core": "workspace:^"
  },
  "peerDependencies": {
    "@adonisjs/core": "^6.12.0"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^7.8.0",
    "@adonisjs/core": "^6.17.0",
    "@agora/durable-core": "workspace:*",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  },
  "engines": { "node": ">=20.6.0" },
  "keywords": ["adonisjs", "adonis", "durable", "workflow", "saga", "agora"]
}
