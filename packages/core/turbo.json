{
  "$schema": "https://turbo.build/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "dependsOn": [],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "dependsOn": [],
      "outputs": ["*.tsbuildinfo"]
    },
    "test": {
      "dependsOn": ["@agora/durable-testing#build"],
      "outputs": ["coverage/**"]
    }
  }
}
