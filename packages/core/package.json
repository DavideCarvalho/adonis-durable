{
  "name": "@agora/durable-core",
  "version": "0.1.0",
  "description": "Durable workflows for AdonisJS — core interfaces, engine and deterministic replay. Part of the Agora ecosystem.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DavideCarvalho/adonis-durable.git",
    "directory": "packages/core"
  },
  "author": "Davi Carvalho <davi@goflip.ai>",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    }
  },
  "files": ["dist/", "README.md", "CHANGELOG.md"],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "cron-parser": "^4.0.0 || ^5.0.0",
    "zod": "^3.0.0 || ^4.0.0"
  },
  "peerDependenciesMeta": {
    "cron-parser": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "cron-parser": "^4.9.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0",
    "zod": "^3.25.0"
  },
  "engines": { "node": ">=20.6.0" },
  "keywords": ["adonisjs", "adonis", "durable", "workflow", "saga", "replay", "agora"]
}
