{
  "name": "@agora/durable-admission-redis",
  "version": "0.1.0",
  "description": "Redis-backed global admission backend for @agora/durable-core — fleet-wide concurrency/rate/priority/fairness for queued remote steps. Part of the Agora ecosystem.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DavideCarvalho/adonis-durable.git",
    "directory": "packages/admission-redis"
  },
  "author": "Davi Carvalho <davi@goflip.ai>",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    }
  },
  "files": ["dist/", "README.md", "CHANGELOG.md"],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@agora/durable-core": "workspace:^"
  },
  "peerDependencies": {
    "@adonisjs/redis": "^9.0.0",
    "ioredis": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "@adonisjs/redis": {
      "optional": true
    }
  },
  "devDependencies": {
    "@agora/durable-core": "workspace:*",
    "@agora/durable-testing": "workspace:*",
    "@types/node": "^20.0.0",
    "ioredis": "^5.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  },
  "engines": { "node": ">=20.6.0" },
  "keywords": [
    "adonisjs",
    "adonis",
    "durable",
    "workflow",
    "redis",
    "admission",
    "concurrency",
    "agora"
  ]
}
