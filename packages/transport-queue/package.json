{
  "name": "@agora/durable-transport-queue",
  "version": "0.1.0",
  "description": "A @adonisjs/queue-backed Transport for @agora/durable-core — dispatch durable remote steps to queue workers. Part of the Agora ecosystem.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DavideCarvalho/adonis-durable.git",
    "directory": "packages/transport-queue"
  },
  "author": "Davi Carvalho <davi@goflip.ai>",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    }
  },
  "files": ["dist/", "README.md", "DESIGN.md", "CHANGELOG.md"],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@agora/durable-core": "workspace:^"
  },
  "peerDependencies": {
    "@adonisjs/core": "^6.12.0 || ^7.0.0",
    "@adonisjs/queue": "^0.6.0"
  },
  "devDependencies": {
    "@adonisjs/queue": "^0.6.1",
    "@agora/durable-core": "workspace:*",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0",
    "zod": "^3.23.0"
  },
  "engines": { "node": ">=20.6.0" },
  "keywords": ["adonisjs", "adonis", "durable", "workflow", "queue", "transport", "agora"]
}
