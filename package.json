{
  "name": "adonis-durable",
  "version": "0.1.0",
  "private": true,
  "description": "Durable cross-app workflows for the Agora AdonisJS ecosystem.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DavideCarvalho/adonis-durable.git"
  },
  "author": "Davi Carvalho <davi@goflip.ai>",
  "packageManager": "pnpm@11.13.0",
  "engines": {
    "node": ">=20.6.0"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "changeset": "changeset",
    "release": "pnpm --filter './packages/*' build && changeset publish",
    "version-packages": "changeset version && biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.27.0",
    "@swc/core": "^1.15.40",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "unplugin-swc": "^1.5.9",
    "vitest": "^3.0.0"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "msgpackr-extract"
    ]
  }
}
